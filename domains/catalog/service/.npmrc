# Route the private `@bookshop-example` package scope to the Bookshop's Google
# Artifact Registry npm repository.
@bookshop-example:registry=https://europe-west1-npm.pkg.dev/bookshop-example-common/npm/

# Authenticate to that registry with a short-lived GCP access token.
# Causa injects it as the `NPM_TOKEN` environment variable for every npm command
# it runs (`javascript.npm.environment.NPM_TOKEN` -> the `gcpAccessToken` secret
# in causa.typescript.yaml), and as a Docker build secret when building service
# images.
//europe-west1-npm.pkg.dev/bookshop-example-common/npm/:_authToken=${NPM_TOKEN}
